{
  "name": "spatial-3d-configurator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev-5174": "vite --port 5174",
    "build": "vite build && node -e \"const fs = require('fs'); fs.rmSync('dist/model/glb/turbine.glb', { force: true });\"",
